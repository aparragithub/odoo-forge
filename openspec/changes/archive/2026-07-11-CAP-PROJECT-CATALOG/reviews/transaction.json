        "src/odoo_forge/project_catalog/resolver.py:34",
        "src/odoo_forge/project_catalog/models.py:8",
        "tests/project_catalog/test_resolver.py:50"
      ]
    },
    {
      "id": "READABILITY-002",
      "lens": "readability",
      "location": "src/odoo_forge/project_catalog/resolver.py:78",
      "severity": "WARNING",
      "claim": "_assemble enforces its not-None invariant for manifest_ref, source_context, and the default fields with bare assert statements. The invariant is actually established by a separate invalid_required_fields call in resolve(), so _assemble's safety depends on an undocumented cross-function contract, and assert is stripped under python -O.",
      "proof_refs": [
        "src/odoo_forge/project_catalog/resolver.py:78",
